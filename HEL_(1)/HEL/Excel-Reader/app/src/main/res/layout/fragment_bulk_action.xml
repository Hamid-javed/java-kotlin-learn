<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFF8F0"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvBulkEditHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Bulk Edit"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:fontFamily="@font/poppins_extrabold" />

        <ImageView
            android:id="@+id/ivClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="Close"
            android:padding="4dp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="8dp" />

    <!-- Counts Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Counts"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/purple"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="2dp"
        android:fontFamily="@font/poppins_medium" />

    <CheckBox
        android:id="@+id/cbResetEncountered"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reset Encountered Count"
        android:textSize="14sp"
        android:paddingStart="4dp"
        android:minHeight="40dp"
        android:fontFamily="@font/poppins_light" />

    <CheckBox
        android:id="@+id/cbResetViewed"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reset Viewed Count"
        android:textSize="14sp"
        android:paddingStart="4dp"
        android:minHeight="40dp"
        android:fontFamily="@font/poppins_light" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp" />

    <!-- Tags Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tags"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/purple"
        android:layout_marginBottom="2dp"
        android:fontFamily="@font/poppins_medium" />

    <CheckBox
        android:id="@+id/cbRemoveAllTags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Remove All Tags"
        android:textSize="14sp"
        android:paddingStart="4dp"
        android:minHeight="40dp"
        android:fontFamily="@font/poppins_light" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <CheckBox
            android:id="@+id/cbAddTag"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Tag:"
            android:textSize="14sp"
            android:paddingStart="4dp"
            android:fontFamily="@font/poppins_light" />

        <EditText
            android:id="@+id/etAddTag"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:hint="Enter tag"
            android:inputType="text"
            android:enabled="false"
            android:maxLines="1"
            android:textSize="13sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:background="@android:drawable/edit_text"
            android:fontFamily="@font/poppins_light" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp" />

    <!-- Timestamps Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Timestamps"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/purple"
        android:layout_marginBottom="2dp"
        android:fontFamily="@font/poppins_medium" />

    <CheckBox
        android:id="@+id/cbResetCreatedAt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reset Created At"
        android:textSize="14sp"
        android:paddingStart="4dp"
        android:minHeight="40dp"
        android:fontFamily="@font/poppins_light" />

    <CheckBox
        android:id="@+id/cbResetModifiedAt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reset Modified At"
        android:textSize="14sp"
        android:paddingStart="4dp"
        android:minHeight="40dp"
        android:fontFamily="@font/poppins_light" />

    <CheckBox
        android:id="@+id/cbResetFirstViewedAt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reset First Viewed At"
        android:textSize="14sp"
        android:paddingStart="4dp"
        android:minHeight="40dp"
        android:fontFamily="@font/poppins_light" />

    <CheckBox
        android:id="@+id/cbResetFirstEncounteredAt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reset First Encountered At"
        android:textSize="14sp"
        android:paddingStart="4dp"
        android:minHeight="40dp"
        android:fontFamily="@font/poppins_light" />

    <CheckBox
        android:id="@+id/cbResetLastViewedAt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reset Last Viewed At"
        android:textSize="14sp"
        android:paddingStart="4dp"
        android:minHeight="40dp"
        android:fontFamily="@font/poppins_light" />

    <CheckBox
        android:id="@+id/cbResetLastEncounteredAt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reset Last Encountered At"
        android:textSize="14sp"
        android:paddingStart="4dp"
        android:minHeight="40dp"
        android:fontFamily="@font/poppins_light" />

    <CheckBox
        android:id="@+id/cbResetLastParaCreatedAt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reset Last Article Created At"
        android:textSize="14sp"
        android:paddingStart="4dp"
        android:minHeight="40dp"
        android:fontFamily="@font/poppins_light" />

    <!-- Apply Button -->
    <Button
        android:id="@+id/btnApplyBulk"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Apply Changes (0)"
        android:enabled="false"
        android:layout_marginTop="8dp"
        android:backgroundTint="#333333"
        android:textColor="@android:color/white"
        android:fontFamily="@font/poppins_extrabold" />

</LinearLayout>
