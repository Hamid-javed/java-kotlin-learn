<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/steel"
    tools:context=".fragments.CarouselFragment">

    <!-- Top bar: speaker, card counter, result count, close -->
    <ImageView
        android:id="@+id/ivSpeaker"
        android:layout_width="28dp"
        android:layout_height="38dp"
        android:src="@drawable/ic_speaker_on"
        app:tint="@color/black"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <ProgressBar
        android:id="@+id/pbSpeakerLoading"
        style="@android:style/Widget.ProgressBar.Small"
        android:layout_width="28dp"
        android:layout_height="38dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:indeterminate="true"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/tvCardPosition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:fontFamily="@font/poppins_medium"
        android:text="Card 1 of 0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/ivCancel"
        app:layout_constraintBottom_toBottomOf="@+id/ivCancel"/>

    <TextView
        android:id="@+id/tvResultCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:alpha="0.7"
        android:text="total:"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@+id/ivCancel"
        android:textColor="@color/black"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="@+id/ivCancel"
        app:layout_constraintEnd_toStartOf="@+id/ivCancel" />

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/close"
        android:id="@+id/ivCancel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"/>

    <!-- Selection row -->
    <LinearLayout
        android:id="@+id/llSelection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@+id/ivCancel"
        app:layout_constraintEnd_toEndOf="@+id/ivCancel">

        <TextView
            android:id="@+id/tvSelectionCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"
            android:text="0/0 selected" />

        <CheckBox
            android:id="@+id/cbSelectAll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Timer -->
    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textAlignment="center"
        android:textColor="@color/black"
        android:textSize="48sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/llSelection"
        tools:text="0:00"/>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvList"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toTopOf="@+id/llNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvTimer"
        tools:listitem="@layout/carousel_item"/>

    <!-- Navigation bar: first, prev, position input, next, last, shuffle, pause -->
    <HorizontalScrollView
        android:id="@+id/llNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#20000000"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@+id/btnGeneratePara"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="8dp"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btnFirst"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="First card"
            android:scaleType="centerInside"
            app:tint="@color/black"/>

        <ImageButton
            android:id="@+id/btnPrev"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_rew"
            android:contentDescription="Previous card"
            android:scaleType="centerInside"
            app:tint="@color/black"/>

        <EditText
            android:id="@+id/etGoToCard"
            android:layout_width="56dp"
            android:layout_height="36dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/edit_text_bg"
            android:hint="1"
            android:inputType="number"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textColorHint="@color/black"
            android:textSize="14sp"
            android:padding="4dp"
            android:imeOptions="actionGo"
            android:maxLength="5"/>

        <ImageButton
            android:id="@+id/btnGoToCard"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_send"
            android:contentDescription="Go to card"
            android:scaleType="centerInside"
            app:tint="@color/black"/>

        <ImageButton
            android:id="@+id/btnNext"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_ff"
            android:contentDescription="Next card"
            android:scaleType="centerInside"
            app:tint="@color/black"/>

        <ImageButton
            android:id="@+id/btnLast"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_next"
            android:contentDescription="Last card"
            android:scaleType="centerInside"
            app:tint="@color/black"/>

        <View
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:layout_marginHorizontal="8dp"
            android:background="@color/black"
            android:alpha="0.3"/>

        <ImageButton
            android:id="@+id/btnShuffle"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/stat_notify_sync"
            android:contentDescription="Shuffle cards"
            android:scaleType="centerInside"
            app:tint="@color/black"/>

        <ImageButton
            android:id="@+id/btnPauseAutoScroll"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_pause"
            android:contentDescription="Pause auto-scroll"
            android:scaleType="centerInside"
            android:visibility="gone"
            app:tint="@color/black"/>

    </LinearLayout>

    </HorizontalScrollView>

    <Button
        android:id="@+id/btnGeneratePara"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Generate Para"
        android:visibility="gone"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvNoResults"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="No matching results found"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:gravity="center"
        android:visibility="gone"
        android:padding="20dp"/>

    <View
        android:id="@+id/generationBarrier"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#40000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>
