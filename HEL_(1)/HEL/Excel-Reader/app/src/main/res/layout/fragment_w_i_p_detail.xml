<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.WIPDetailFragment">

<androidx.core.widget.NestedScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/steel"
    android:fillViewport="true"
    tools:context=".fragments.WIPDetailFragment">



        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/imgBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:src="@drawable/back_arrow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/btnStopTTS"
                android:layout_width="30dp"
                android:layout_height="40dp"
                android:visibility="gone"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                android:src="@drawable/ic_speaker_off"
                app:tint="@color/black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />



            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="16dp"
                android:layout_marginTop="32dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:orientation="vertical"
                android:padding="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/imgBack">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">


                    <EditText
                        android:id="@+id/txtWord"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:layout_weight="3"
                        android:fontFamily="@font/poppins_extrabold"
                        android:background="@null"
                        android:inputType="text"
                        tools:text="Scramble"
                        android:textSize="20sp" />

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="40dp"
                        android:id="@+id/ivSpeaker"
                        android:src="@drawable/speaker" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:layout_weight="3"
                        android:fontFamily="@font/poppins_extrabold"
                        android:text="Meaning" />

                        <ImageView
                            android:id="@+id/ivSpeakerMeaning"
                            android:layout_width="28dp"
                            android:layout_height="30dp"
                            android:src="@drawable/speaker"
                            app:tint="@color/black" />


                    </LinearLayout>
                    <EditText
                        android:id="@+id/txtMeaning"
                        android:layout_width="match_parent"
                        android:textColor="@color/black"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_medium"
                        android:background="@null"
                        android:inputType="textMultiLine"
                        tools:text="run with light steps out of fear or excitement run with light steps out of fear or excitement"
                        android:textSize="18sp" />
                </LinearLayout>




                <TextView
                    android:id="@+id/tvGenerateSentence"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Generate AI sentence"
                    android:textColor="@color/black"
                    android:padding="8dp"
                    android:background="@drawable/back_box"
                    android:clickable="true"
                    android:focusable="true"
                    android:textSize="14sp"/>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:padding="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_extrabold"
                        android:textColor="@color/black"
                        android:layout_weight="3"
                        android:padding="8dp"
                        android:text="Sample Sentence" />

                    <ImageView
                        android:id="@+id/ivSpeakerSentence"
                        android:layout_width="28dp"
                        android:layout_height="40dp"
                        android:src="@drawable/speaker"
                        app:tint="@color/black" />

                </LinearLayout>
                    <EditText
                        android:id="@+id/txtSampleSentence"
                        android:layout_width="match_parent"
                        android:textColor="@color/black"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_medium"
                        android:background="@null"
                        android:inputType="textMultiLine"
                        tools:text="The mouse scampered away from the cat into its hole."
                        android:textSize="16sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_extrabold"
                        android:textColor="@color/black"
                        android:text="Category" />

                    <EditText
                        android:id="@+id/txtCategory"
                        android:layout_width="match_parent"
                        android:textColor="@color/black"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_medium"
                        android:background="@null"
                        android:inputType="text"
                        tools:text="Word"
                        android:textSize="16sp" />
                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_extrabold"
                        android:textColor="@color/black"
                        android:text="Tags" />

                    <LinearLayout
                        android:id="@+id/llTagsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="8dp" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <AutoCompleteTextView
                            android:id="@+id/etTag"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="20dp"
                            android:maxLines="1"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:hint="Type tag"
                            android:completionThreshold="1"
                            android:inputType="text"
                            app:layout_constraintEnd_toStartOf="@id/btnAddTag"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:fontFamily="@font/poppins_medium"
                            android:backgroundTint="@color/black"
                            android:textColor="@color/black"
                            android:textSize="16sp" />

                        <Button
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/btnAddTag"
                            app:layout_constraintTop_toTopOf="@id/etTag"
                            app:layout_constraintBottom_toBottomOf="@id/etTag"
                            app:layout_constraintEnd_toEndOf="parent"
                            android:text="Add" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>



                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_extrabold"
                        android:text="Viewed" />

                    <ImageButton
                        android:id="@+id/btnViewedMinus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_decrease"
                        app:tint="@color/black"
                        android:background="@null"
                        android:contentDescription="decrease viewed" />

                    <TextView
                        android:id="@+id/txtViewCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="60dp"
                        android:fontFamily="@font/poppins_medium"
                        android:gravity="center"
                        android:textColor="@color/black"
                        tools:text="0 times"
                        android:textSize="16sp" />

                    <ImageButton
                        android:id="@+id/btnViewedPlus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_increase"
                        app:tint="@color/black"
                        android:background="@null"
                        android:contentDescription="increase viewed" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reset Viewed"
                    android:textColor="#E62525"
                    android:layout_marginTop="5dp"
                    android:id="@+id/dViewed">

                </TextView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_extrabold"
                        android:text="Encountered" />

                    <ImageButton
                        android:id="@+id/btnEncounterMinus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_decrease"
                        app:tint="@color/black"
                        android:background="@null"
                        android:contentDescription="decrease encountered" />

                    <TextView
                        android:id="@+id/txtReadCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="60dp"
                        android:fontFamily="@font/poppins_medium"
                        android:gravity="center"
                        android:textColor="@color/black"
                        tools:text="0 times"
                        android:textSize="16sp" />

                    <ImageButton
                        android:id="@+id/btnEncounterPlus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_increase"
                        app:tint="@color/black"
                        android:background="@null"
                        android:contentDescription="increase encountered" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Reset Encountered"
                    android:textColor="#E62525"
                    android:layout_marginTop="5dp"
                    android:id="@+id/dEncountered">

                </TextView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_extrabold"
                        android:text="Para Created" />

                    <TextView
                        android:id="@+id/tvParaCreatedAt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:fontFamily="@font/poppins_medium"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:textColor="@color/black"
                        android:text="-"
                        android:textSize="16sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="5dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Edit"
                        android:textColor="#1565C0"
                        android:id="@+id/btnEditParaCreatedAt"
                        android:layout_marginEnd="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reset Para Timestamp"
                        android:textColor="#E62525"
                        android:id="@+id/dParaCreatedAt"/>

                </LinearLayout>



                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="?android:attr/listDivider"
                    android:layout_marginBottom="8dp"
                    android:layout_marginTop="8dp"/>
                <TextView
                    android:id="@+id/tvCreatedAt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Created at: -"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:paddingTop="8dp"/>

                <TextView
                    android:id="@+id/tvModifiedAt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Modified at: -"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/black"
                    android:textSize="14sp"

                    android:paddingTop="4dp"/>

                <TextView
                    android:id="@+id/tvLastViewedAt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last viewed: -"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:paddingTop="4dp"/>

                <TextView
                    android:id="@+id/tvLastEncounteredAt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last encountered: -"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:paddingTop="4dp"/>

                <TextView
                    android:id="@+id/tvFirstViewedAt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="First viewed at: -"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:paddingTop="4dp"/>

                <TextView
                    android:id="@+id/tvFirstEncounteredAt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="First encountered at: -"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/black"
                    android:textSize="14sp"
                    android:paddingTop="4dp"/>

                <Button
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:layout_gravity="center"
                    android:id="@+id/btnEdit"
                    android:text="Save WIP"
                    />
                <Button
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Delete WIP"
                    android:id="@+id/tvDeleteWIP"
                    android:layout_marginTop="25dp">

                </Button>


            </LinearLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
    <View
        android:id="@+id/generationBarrier"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>